# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# Go API
API_PORT=8080
API_ENV=development
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres
CORS_ORIGIN=http://localhost:3000

# 외부 데이터 소스 (W2a)
FRED_API_KEY=                                    # https://fred.stlouisfed.org/docs/api/api_key.html
ECOS_API_KEY=                                    # https://ecos.bok.or.kr/api/

# AI (W4) — 빈 값이면 MockClient로 dev 검증 가능. 실 채팅은 키 발급 필요.
ANTHROPIC_API_KEY=                               # https://console.anthropic.com/

# 관측
NEXT_PUBLIC_SENTRY_DSN_WEB=
SENTRY_DSN_API=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# 기능 플래그
PAYMENTS_ENABLED=false
ENABLE_ADS=false                  # 서버 측 (cron·문서 토글)
NEXT_PUBLIC_ENABLE_ADS=false      # 클라이언트 측 (AdSlot — Next.js inline)

# AdSense (NEXT_PUBLIC_ENABLE_ADS=true일 때만 유효)
NEXT_PUBLIC_ADSENSE_CLIENT=                              # 예: ca-pub-1234567890123456
NEXT_PUBLIC_ADSENSE_SLOT_MARKET_BOTTOM=                  # 마켓 페이지 하단 슬롯 ID

# Toss 개인 후원 링크 (미설정 시 사이드바 후원 아이콘 비표시)
NEXT_PUBLIC_TOSS_DONATION_URL=                           # 예: https://toss.me/your-nickname
